function MiniBarChart({ rows, field, maxVal, color="#1e3a8a", height=100, formatLabel }){
  if(!rows||!rows.length) return null;
  const mx = maxVal || Math.max(...rows.map(r=>r[field]||0), 1);
  const barW = Math.max(12, Math.floor(580 / rows.length) - 6);
  const totalW = rows.length * (barW + 6);
  return(
    <svg width="100%" viewBox={`0 0 ${totalW} ${height+28}`} style={{display:"block",overflow:"visible"}}>
      {rows.map((r,i)=>{
        const v = r[field]||0;
        const bh = Math.max(2, Math.round(v/mx*height));
        const x = i*(barW+6);
        return(
          <g key={i}>
            <rect x={x} y={height-bh} width={barW} height={bh} fill={color} rx={3} opacity={v===0?0.15:0.85}/>
            <text x={x+barW/2} y={height+14} textAnchor="middle" fontSize={10} fill="#64748b">{r.label}</text>
            {v>0&&<text x={x+barW/2} y={height-bh-4} textAnchor="middle" fontSize={9} fill={color} fontWeight={600}>
              {formatLabel?formatLabel(v):v}
            </text>}
          </g>
        );
      })}
    </svg>
  );
}

