// Tính công nợ KH cho 1 đơn
// Tính tổng tiền KH phải trả (có VAT nếu đơn có HĐ)
// Ưu tiên dùng totalWithVat đã lưu, fallback tính từ vatRate
function calcOrderTotal(order){
  if(order.invoiceType==="invoice"){
    if(order.pricing?.totalWithVat) return order.pricing.totalWithVat;
    const rev     = order.pricing?.totalRevenue||0;
    const vatRate = order.pricing?.vatRate||8;
    return Math.round(rev*(1+vatRate/100));
  }
  return order.pricing?.totalRevenue||0;
}

function calcDebt(order, vouchers){
  const paid = vouchers.filter(v=>v.orderId===order.id&&v.type==="thu"&&v.status==="approved").reduce((s,v)=>s+v.amount,0);
  return Math.max(0, calcOrderTotal(order)-paid);
}

// Phân loại mức độ nguy hiểm công nợ
function debtRisk(order, debt, vouchers){
  if(debt<=0) return null;
  const now = new Date(NOW_ISO);
  const depart = order.departDate ? new Date(order.departDate) : null;
  const returnD = order.returnDate ? new Date(order.returnDate) : null;
  const daysAfterReturn = returnD ? Math.floor((now-returnD)/86400000) : null;
  const daysToDepart    = depart  ? Math.ceil((depart-now)/86400000)   : null;
  if(daysAfterReturn!==null && daysAfterReturn>7) return {level:"critical", label:"Đã về >7 ngày chưa trả", color:"#8b2a1a", bg:"#fdf0ee", dot:"#e07060"};
