            borderRadius:"var(--r-sm)",fontSize:"var(--text-sm)",background:"var(--c-surface-2)",outline:"none"}}/>
      </div>


      {showForm&&(


      <div style={{display:"flex",gap:8,marginBottom:12,flexWrap:"wrap",alignItems:"center"}}>
        <div style={{display:"flex",gap:4,background:"#e0e7ff",borderRadius:10,padding:3}}>
          {[["active","✈ Đang bảo lưu"],["expiring","⚠️ Sắp hết hạn"],["expired","🔴 Hết hạn"],["all","Tất cả"]].map(([k,l])=>(
            <button key={k} onClick={()=>setFilterTab(k)} style={{padding:"6px 14px",borderRadius:8,border:"none",
              background:filterTab===k?"#fff":"transparent",fontWeight:filterTab===k?600:400,fontSize:12,
