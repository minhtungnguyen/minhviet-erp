// ── Message Composer (thiệp/email) ────────────────────────
function MessageComposer({c,event,onClose,onSend,currentUser}){
  const tplKey = event?.type||"birthday";
  const tpl    = MSG_TEMPLATES[tplKey]||MSG_TEMPLATES.birthday;
  const [subject,setSubject]=useState(buildMessage(tpl.subject,c,event||{}));
  const [body,   setBody]   =useState(buildMessage(tpl.body,c,event||{}));
  const [channel,setChannel]=useState("email");
  const [copied, setCopied] =useState(false);
  const [sent,   setSent]   =useState(false);

  const logSend=(ch)=>{
    if(onSend){
      onSend({
        id: "MSG-"+Date.now(),
        ts: new Date().toISOString(),
        customerId: c.id,
        customerName: c.type==="business"?c.companyName:c.name,
        customerPhone: c.phone,
        channel: ch,
        eventType: tplKey,
        eventLabel: event?.label||CRM_EVENT_TYPES[tplKey]?.label||"Thông điệp",
        subject,
        body,
        sentBy: currentUser?.name||"—",
      });
    }
    setSent(true);
  };

  const handleCopy=()=>{
    navigator.clipboard.writeText(channel==="email"?`Chủ đề: ${subject}\n\n${body}`:body);
    setCopied(true); setTimeout(()=>setCopied(false),2000);
    logSend(channel);
  };
  const handleOpenEmail=()=>{
    const mailLink=`mailto:${c.email||""}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.open(mailLink,"_blank");
    logSend("email");
        <div style={{marginBottom:14}}>
          <label style={{display:"block",fontSize:11,fontWeight:600,color:"#475569",marginBottom:5,textTransform:"uppercase",letterSpacing:.4}}>Nội dung</label>
          <textarea value={body} onChange={e=>setBody(e.target.value)} rows={10}
            style={{width:"100%",padding:"10px 12px",border:"1px solid #dbeafe",borderRadius:8,fontSize:13,background:"#f8faff",outline:"none",resize:"vertical",fontFamily:"inherit",boxSizing:"border-box",lineHeight:1.6}}/>
        </div>


        <div style={{background:"#f0f4ff",borderRadius:8,padding:"9px 12px",marginBottom:14,fontSize:12,color:"#475569"}}>
          <span style={{fontWeight:600}}>Gửi đến:</span> {c.type==="business"?c.companyName:c.name}
          {c.email&&<span style={{marginLeft:8}}>· ✉️ {c.email}</span>}
          {c.phone&&<span style={{marginLeft:8}}>· 📞 {c.phone}</span>}
        </div>


        <div style={{background:"#fef9e7",border:"1px solid #e8c53a",borderRadius:8,padding:"9px 12px",marginBottom:14,fontSize:12,color:"#7a5a00",lineHeight:1.5}}>
          💡 <strong>Gửi thủ công:</strong> Dùng nút bên dưới để mở Gmail/Zalo với nội dung điền sẵn, hoặc Copy rồi paste vào ứng dụng bạn dùng.
          Tích hợp gửi tự động sẽ được kích hoạt sau khi deploy với Supabase + Resend.
        </div>

        <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>
          <button onClick={handleCopy}
            style={{flex:1,padding:"10px",background:copied?"#e8f5ef":"#eff6ff",border:`1px solid ${copied?"#34b27c":"#bfdbfe"}`,borderRadius:8,fontSize:13,fontWeight:600,cursor:"pointer",color:copied?"#1d6b4f":"#1e3a8a"}}>
            {copied?"✓ Đã copy!":"📋 Copy nội dung"}
          </button>
          {c.email&&channel==="email"&&(
            <button onClick={handleOpenEmail}
              style={{flex:1,padding:"10px",background:"linear-gradient(135deg,#1e3a8a,#2563eb)",border:"none",borderRadius:8,fontSize:13,fontWeight:600,cursor:"pointer",color:"#fff",display:"flex",alignItems:"center",justifyContent:"center",gap:6}}>
              ✉️ Mở Gmail
            </button>
          )}
          {c.phone&&channel==="zalo"&&(
            <button onClick={handleOpenZalo}
              style={{flex:1,padding:"10px",background:"linear-gradient(135deg,#0068ff,#00aaff)",border:"none",borderRadius:8,fontSize:13,fontWeight:600,cursor:"pointer",color:"#fff"}}>
              💬 Mở Zalo
