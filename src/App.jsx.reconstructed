            </div>
            <div style={{display:"flex",flexWrap:"wrap",gap:6}}>
              {VOUCHER_SERVICES.map(svc=>{
                const on=services.includes(svc);
                return(
                  <button key={svc} onClick={()=>toggleService(svc)}
                    style={{padding:"5px 11px",borderRadius:20,border:"1.5px solid "+(on?discountColor:"#e0e7ff"),
                      background:on?discountBg:"#f8faff",color:on?discountColor:"#64748b",
                      fontSize:12,fontWeight:on?600:400,cursor:"pointer",transition:"all .12s"}}>
                    {on?"✓ ":""}{svc}
                  </button>
                );
              })}
            </div>
          </div>

          {/* Expiry + Code */}
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:14}}>
