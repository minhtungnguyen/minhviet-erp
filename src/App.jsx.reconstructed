            <div style={{fontSize:11,fontWeight:600,color:"#64748b",textTransform:"uppercase",letterSpacing:.4,marginBottom:8}}>Mức giảm giá</div>
            <div style={{display:"flex",gap:8}}>
              {[5,10,15,20,30].map(pct=>(
                <button key={pct} onClick={()=>setDiscount2(pct)}
                  style={{flex:1,padding:"10px 0",borderRadius:10,border:"2px solid "+(discount===pct?discountColor:"#e0e7ff"),
                    background:discount===pct?discountBg:"#f8faff",
                    color:discount===pct?discountColor:"#64748b",
                    fontWeight:discount===pct?800:500,fontSize:14,cursor:"pointer",transition:"all .15s"}}>
                  -{pct}%
                </button>
              ))}
            </div>
          </div>

          {/* Services */}
