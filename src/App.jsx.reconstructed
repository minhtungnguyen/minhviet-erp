        <StatCard label="LN THẤP / CẢNH BÁO" value={stats.lowProfit}               sub="Cần GĐ xem xét"                                   color={stats.lowProfit>0?"var(--c-danger)":"var(--c-text-muted)"}   onClick={()=>setFilterPrice("warning")}/>
