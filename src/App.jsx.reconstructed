function CrmAnalytics({ customers, orders, onSelectCustomer }){
  const now = new Date(NOW_ISO);
  const curPrefix  = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,"0")}`;
  const prev3Month = new Date(now); prev3Month.setMonth(prev3Month.getMonth()-3);
  const prev6Month = new Date(now); prev6Month.setMonth(prev6Month.getMonth()-6);
