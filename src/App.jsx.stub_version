function SettingsView({ approvalThreshold, onUpdateThreshold, onBack, pushNotif }) {
  const [thresh, setThresh] = useState(approvalThreshold);
  return (
    <div style={{maxWidth:600,margin:"0 auto"}}>
      <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:16}}>
        <Btn variant="outline" size="sm" onClick={onBack}>← Danh sách</Btn>
        <div style={{fontSize:18,fontWeight:700,color:"#1e3a8a"}}>⚙️ Cài đặt hệ thống</div>
      </div>
      <Card>
        <div style={{fontSize:14,fontWeight:600,color:"#1e3a8a",marginBottom:16}}>Quy trình phê duyệt chi</div>
        <div style={{background:"#f0f4ff",borderRadius:10,padding:"14px 16px",marginBottom:14,fontSize:12,color:"#64748b"}}>
          Phiếu chi dưới ngưỡng: KT duyệt → chuyển tiền.<br/>
          Từ ngưỡng trở lên: KT duyệt → <strong style={{color:"#1e3a8a"}}>GĐ phê duyệt</strong> → chuyển tiền.
        </div>
        <FieldWrap label="Ngưỡng cần GĐ phê duyệt (đ)">
          <input type="number" min={0} value={thresh} onChange={e=>setThresh(+e.target.value)}
            style={{width:"100%",padding:"10px 12px",border:"1px solid #dbeafe",borderRadius:8,
              fontSize:15,fontWeight:700,color:"#1e3a8a",background:"#f8faff",
              outline:"none",boxSizing:"border-box",textAlign:"right",fontVariantNumeric:"tabular-nums"}}/>
          {thresh>0&&<div style={{fontSize:11,color:"#64748b",marginTop:4,textAlign:"right"}}>{fmt(thresh)} đ</div>}
        </FieldWrap>
        <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:12}}>
          {[5000000,10000000,20000000,50000000].map(v=>(
            <button key={v} onClick={()=>setThresh(v)}
              style={{padding:"6px 14px",borderRadius:20,border:"1px solid "+(thresh===v?"#1e3a8a":"#dbeafe"),
                background:thresh===v?"#1e3a8a":"#f8faff",color:thresh===v?"#fff":"#64748b",
                fontSize:12,cursor:"pointer",fontWeight:thresh===v?600:400}}>
              {fmtS(v)}đ
            </button>
          ))}
        </div>
        <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
          <Btn variant="outline" onClick={onBack}>Hủy</Btn>
          <Btn onClick={()=>{if(onUpdateThreshold)onUpdateThreshold(thresh);onBack();pushNotif("Đã cập nhật ngưỡng duyệt: "+fmtS(thresh)+"đ","success");}}>
            💾 Lưu cài đặt
          </Btn>
        </div>
      </Card>
    </div>
  );
}

function UserManagementPage({ userAccounts, onUpdateAccounts, currentUser, pushNotif, personalTargets=[], onUpdateTargets, approvalThreshold=20000000, onUpdateThreshold }){ return null; }
function NotifPanel({notifs,onClose,onMarkAll}){ return null; }
// ═══════════════════════════════════════════════════════════
// ROOT APP
// ═══════════════════════════════════════════════════════════
// ═══════════════════════════════════════════════════════════
// USER ACCOUNTS — danh sách tài khoản nội bộ
// Sau này thay bằng Supabase Auth, giữ nguyên cấu trúc này
// ═══════════════════════════════════════════════════════════
function ProfilePage({ currentUser, onUpdate, onBack, pushNotif }){ return null; }

function SimpleOrderForm({ onSave, onCancel, currentUser }) {
  const [form, setForm] = useState({ customer:{name:"",phone:""}, product:"", type:"tour", departDate:"", returnDate:"", pax:1, totalPrice:0, notes:"", saleName:currentUser?.name||"" });
  const set = (k,v) => setForm(f=>({...f,[k]:v}));
  const setC = (k,v) => setForm(f=>({...f,customer:{...f.customer,[k]:v}}));
  return (
    <div style={{display:"grid",gap:14}}>
      {[["Tên khách hàng","text",form.customer.name,v=>setC("name",v)],["Điện thoại","text",form.customer.phone,v=>setC("phone",v)],["Sản phẩm/Tour","text",form.product,v=>set("product",v)],["Ngày đi","date",form.departDate,v=>set("departDate",v)],["Ngày về","date",form.returnDate,v=>set("returnDate",v)],["Số khách","number",form.pax,v=>set("pax",+v)],["Tổng tiền (đ)","number",form.totalPrice,v=>set("totalPrice",+v)],["Ghi chú","text",form.notes,v=>set("notes",v)]].map(([label,type,val,handler])=>(
        <div key={label}>
          <label style={{fontSize:12,color:"#64748b",display:"block",marginBottom:4}}>{label}</label>
          <input type={type} value={val} onChange={e=>handler(e.target.value)} style={{width:"100%",border:"1px solid #e2e8f0",borderRadius:6,padding:"8px 10px",fontSize:13,boxSizing:"border-box"}}/>
        </div>
      ))}
      <div style={{display:"flex",gap:10,marginTop:8}}>
        <button onClick={()=>onSave(form)} style={{flex:1,background:"#3b82f6",color:"#fff",border:"none",padding:"10px",borderRadius:8,cursor:"pointer",fontWeight:600}}>Lưu đơn hàng</button>
        <button onClick={onCancel} style={{flex:1,background:"#f1f5f9",border:"none",padding:"10px",borderRadius:8,cursor:"pointer"}}>Hủy</button>
      </div>
    </div>
  );
}
const NAV_ITEMS = [
  { key:"dashboard", label:"Dashboard", icon:"🏠" },
  { key:"orders",    label:"Đơn hàng",  icon:"📋" },
  { key:"crm",       label:"Khách hàng",icon:"👥" },
  { key:"quote",     label:"Báo giá",   icon:"📄" },
  { key:"ncc",       label:"NCC",       icon:"🏢" },
  { key:"invoice",   label:"Hóa đơn",   icon:"🧾" },
  { key:"approvals", label:"Phê duyệt", icon:"✅" },
  { key:"report",    label:"Báo cáo",   icon:"📊" },
  { key:"tourghep",  label:"Tour ghép", icon:"🗺" },
  { key:"aftersale", label:"Sau bán",   icon:"💝" },
  { key:"hdv",       label:"HDV",       icon:"🎯" },
  { key:"accounting",label:"Kế toán",   icon:"💰" },
  { key:"close",     label:"Chốt đơn",  icon:"🔒" },
  { key:"refund",    label:"Hoàn tiền", icon:"↩" },
  { key:"tour",      label:"Chương trình tour", icon:"🌏" },
  { key:"users",     label:"Nhân viên", icon:"👤" },
  { key:"profile",   label:"Hồ sơ",    icon:"⚙" },
];

function Sidebar({ currentRole, view, onNav, currentUser, onLogout, notifs=[], onNotif, onSearch, children }){
  const [collapsed, setCollapsed] = React.useState(false);
  const unread = notifs.filter(n=>!n.read).length;
  return (
    <div style={{display:"flex",minHeight:"100vh"}}>
      <div style={{width:collapsed?56:220,background:"#1e3a8a",color:"#fff",display:"flex",flexDirection:"column",transition:"width .2s",flexShrink:0}}>
        <div style={{padding:"16px 12px",borderBottom:"1px solid rgba(255,255,255,.1)",display:"flex",alignItems:"center",justifyContent:"space-between"}}>
          {!collapsed && <span style={{fontWeight:700,fontSize:15}}>Minh Việt ERP</span>}
          <button onClick={()=>setCollapsed(c=>!c)} style={{background:"none",border:"none",color:"#fff",cursor:"pointer",fontSize:18,padding:4}}>☰</button>
        </div>
        <div style={{flex:1,overflowY:"auto",padding:"8px 0"}}>
          {NAV_ITEMS.map(item=>(
            <button key={item.key} onClick={()=>onNav(item.key)}
              style={{width:"100%",background:view===item.key?"rgba(255,255,255,.15)":"none",border:"none",color:"#fff",padding:"10px 16px",textAlign:"left",cursor:"pointer",display:"flex",alignItems:"center",gap:10,fontSize:13,opacity:.9}}>
              <span style={{fontSize:16,flexShrink:0}}>{item.icon}</span>
              {!collapsed && <span>{item.label}</span>}
            </button>
          ))}
        </div>
        <div style={{padding:"12px",borderTop:"1px solid rgba(255,255,255,.1)"}}>
          {!collapsed && <div style={{fontSize:12,opacity:.7,marginBottom:8}}>{currentUser?.name} — {currentUser?.role}</div>}
          <button onClick={onLogout} style={{width:"100%",background:"rgba(255,255,255,.1)",border:"none",color:"#fff",padding:"8px",borderRadius:6,cursor:"pointer",fontSize:12}}>
            {collapsed?"🚪":"🚪 Đăng xuất"}
          </button>
        </div>
      </div>
      <div style={{flex:1,display:"flex",flexDirection:"column",minWidth:0}}>
        <div style={{background:"#fff",borderBottom:"1px solid #e2e8f0",padding:"12px 20px",display:"flex",alignItems:"center",justifyContent:"space-between"}}>
          <div style={{fontWeight:600,fontSize:15,color:"#1e3a8a"}}>
            {NAV_ITEMS.find(n=>n.key===view)?.label || "Dashboard"}
          </div>
          <div style={{display:"flex",gap:8,alignItems:"center"}}>
            <button onClick={onSearch} style={{background:"#f1f5f9",border:"none",padding:"6px 14px",borderRadius:6,cursor:"pointer",fontSize:13}}>🔍 Tìm kiếm</button>
            <button onClick={onNotif} style={{background:"#f1f5f9",border:"none",padding:"6px 12px",borderRadius:6,cursor:"pointer",position:"relative"}}>
              🔔{unread>0 && <span style={{position:"absolute",top:-4,right:-4,background:"#ef4444",color:"#fff",borderRadius:"50%",width:16,height:16,fontSize:10,display:"flex",alignItems:"center",justifyContent:"center"}}>{unread}</span>}
            </button>
          </div>
        </div>
        <div style={{flex:1,overflow:"auto",padding:20}}>
          {children}
        </div>
      </div>
    </div>
  );
}
function LoginPage({ onLogin, userAccounts=USER_ACCOUNTS }){
  const [username, setUsername] = useState("");
  const [password, setPassword] = useState("");
  const [showPw,   setShowPw]   = useState(false);
  const [error,    setError]    = useState("");
  const [loading,  setLoading]  = useState(false);

  const handleSubmit = (e) => {
    e && e.preventDefault();
    if(!username.trim()||!password.trim()){setError("Vui lòng nhập đầy đủ thông tin");return;}
    setLoading(true); setError("");
    // Simulate async (dễ swap sang Supabase sau)
    setTimeout(()=>{
      const user = userAccounts.find(u=>
        u.username===username.trim().toLowerCase() && u.password===password
      );
      if(user){
        if(user.active===false){ setError("Tài khoản đã bị khóa. Liên hệ Giám đốc để mở lại."); setLoading(false); return; }
        onLogin(user);
      } else {
        setError("Tên đăng nhập hoặc mật khẩu không đúng");
        setLoading(false);
      }
    }, 600);
  };

  return(
    <div style={{minHeight:"100vh",background:"linear-gradient(160deg,#172554 0%,#1e3a8a 40%,#1d4ed8 70%,#2563eb 100%)",display:"flex",alignItems:"center",justifyContent:"center",fontFamily:"'Segoe UI',-apple-system,system-ui,sans-serif",padding:20}}>

      <div style={{position:"fixed",top:-120,right:-120,width:400,height:400,borderRadius:"50%",background:"rgba(255,255,255,.04)",pointerEvents:"none"}}/>
      <div style={{position:"fixed",bottom:-80,left:-80,width:300,height:300,borderRadius:"50%",background:"rgba(255,255,255,.04)",pointerEvents:"none"}}/>
      <div style={{position:"fixed",top:"40%",left:"10%",width:200,height:200,borderRadius:"50%",background:"rgba(255,255,255,.03)",pointerEvents:"none"}}/>

      <div style={{width:"100%",maxWidth:440,position:"relative"}}>

        <div style={{textAlign:"center",marginBottom:28}}>
          <div style={{display:"inline-flex",flexDirection:"column",alignItems:"center",gap:0}}>
            <img src="/LogoMV.png" alt="Minh Việt Travel"
              style={{width:180,height:"auto",marginBottom:8}}/>
            <div style={{fontSize:11,color:"rgba(255,255,255,.5)",letterSpacing:2,marginTop:2}}>— Hệ thống Quản lý ERP nội bộ —</div>
          </div>
        </div>


        <div style={{background:"#fff",borderRadius:20,padding:"32px 36px",boxShadow:"0 24px 64px rgba(0,0,0,.35)"}}>
          <div style={{fontSize:18,fontWeight:700,color:"#1e3a8a",marginBottom:4}}>Đăng nhập hệ thống</div>
          <div style={{fontSize:12,color:"#94a3b8",marginBottom:24}}>Dùng tài khoản được cấp bởi Minh Việt Travel</div>

          {error&&(
            <div style={{background:"#fdf0ee",border:"1px solid #f5c0b5",borderRadius:8,padding:"10px 14px",marginBottom:16,fontSize:13,color:"#8b2a1a",display:"flex",alignItems:"center",gap:8}}>
              <span>⚠</span>{error}
            </div>
          )}

          <div style={{marginBottom:14}}>
            <label style={{display:"block",fontSize:11,fontWeight:600,color:"#555",textTransform:"uppercase",letterSpacing:.5,marginBottom:6}}>Tên đăng nhập</label>
            <input
              value={username} onChange={e=>{setUsername(e.target.value);setError("");}}
              onKeyDown={e=>e.key==="Enter"&&handleSubmit()}
              placeholder="VD: hoa.sale"
              autoComplete="username" autoFocus
              style={{width:"100%",padding:"11px 14px",border:"1px solid #d5d3cb",borderRadius:10,fontSize:14,background:"#f8faff",outline:"none",boxSizing:"border-box",color:"#1e293b",transition:"border-color .15s"}}
              onFocus={e=>e.target.style.borderColor="#1e3a8a"}
              onBlur={e=>e.target.style.borderColor="#cbd5e1"}
            />
          </div>

          <div style={{marginBottom:20}}>
            <label style={{display:"block",fontSize:11,fontWeight:600,color:"#555",textTransform:"uppercase",letterSpacing:.5,marginBottom:6}}>Mật khẩu</label>
            <div style={{position:"relative"}}>
              <input
                type={showPw?"text":"password"}
                value={password} onChange={e=>{setPassword(e.target.value);setError("");}}
                onKeyDown={e=>e.key==="Enter"&&handleSubmit()}
                placeholder="Nhập mật khẩu"
                autoComplete="current-password"
                style={{width:"100%",padding:"11px 44px 11px 14px",border:"1px solid #d5d3cb",borderRadius:10,fontSize:14,background:"#f8faff",outline:"none",boxSizing:"border-box",color:"#1e293b",transition:"border-color .15s"}}
                onFocus={e=>e.target.style.borderColor="#1e3a8a"}
                onBlur={e=>e.target.style.borderColor="#cbd5e1"}
              />
              <button onClick={()=>setShowPw(v=>!v)} style={{position:"absolute",right:12,top:"50%",transform:"translateY(-50%)",background:"none",border:"none",cursor:"pointer",fontSize:16,color:"#aaa",padding:2}}>
                {showPw?"🙈":"👁"}
              </button>
            </div>
          </div>

          <button
            onClick={handleSubmit}
            disabled={loading}
            style={{width:"100%",padding:"13px",background:loading?"#cbd5e1":"linear-gradient(135deg,#1e3a8a,#2563eb)",color:"#fff",border:"none",borderRadius:10,fontSize:15,fontWeight:700,cursor:loading?"not-allowed":"pointer",transition:"all .15s",display:"flex",alignItems:"center",justifyContent:"center",gap:8,boxShadow:loading?"none":"0 4px 16px rgba(37,99,235,.4)"}}>
            {loading?<><span style={{display:"inline-block",width:16,height:16,border:"2px solid rgba(255,255,255,.3)",borderTopColor:"#fff",borderRadius:"50%",animation:"spin .7s linear infinite"}}/> Đang đăng nhập...</>:"Đăng nhập →"}
          </button>

          <style>{"@keyframes spin{to{transform:rotate(360deg)}}"}</style>


          <div style={{marginTop:24,padding:"12px 14px",background:"#f0f4ff",borderRadius:10,border:"1px solid #e8e6df"}}>
            <div style={{fontSize:11,fontWeight:600,color:"#888",textTransform:"uppercase",letterSpacing:.5,marginBottom:8}}>Tài khoản thử nghiệm</div>
            {[
              {u:"hoa.sale",  p:"mv2025",   role:"Sale",      color:"#2563eb"},
              {u:"lien.kt",   p:"mv2025",   role:"Kế toán",   color:"#1a4d8f"},
              {u:"tung.gd",   p:"mv@admin", role:"Giám đốc",  color:"#7a5a00"},
            ].map(a=>(
              <div key={a.u} onClick={()=>{setUsername(a.u);setPassword(a.p);setError("");}}
                style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"5px 8px",borderRadius:6,cursor:"pointer",marginBottom:3,transition:"background .1s"}}
                onMouseEnter={e=>e.currentTarget.style.background="#ede9e0"}
                onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
                <span style={{fontSize:12,color:"#555",fontFamily:"monospace"}}>{a.u}</span>
                <span style={{fontSize:11,fontWeight:600,padding:"2px 8px",borderRadius:20,background:ROLE_CONFIG[a.role==="Sale"?"sale":a.role==="Kế toán"?"accountant":"manager"]?.bg,color:a.color}}>{a.role}</span>
              </div>
            ))}
            <div style={{fontSize:10,color:"#bbb",marginTop:6}}>Click vào dòng để điền nhanh - Xóa hint này trước khi go-live</div>
          </div>
        </div>

        <div style={{textAlign:"center",marginTop:20,fontSize:12,color:"rgba(255,255,255,.4)"}}>
          © 2025 Minh Việt Travel - Hệ thống ERP nội bộ v1.0
        </div>
      </div>
    </div>
  );
}

export default function App(){
  const [currentUser, setCurrentUser] = React.useState(null);
  const [view, setView] = React.useState("dashboard");
  const [orders, setOrders] = React.useState(SEED_ORDERS);
  const [vouchers, setVouchers] = React.useState(SEED_VOUCHERS);
  const [expenses, setExpenses] = React.useState(SEED_EXPENSES);
  const [refunds, setRefunds] = React.useState(SEED_REFUNDS);
  const [customers, setCustomers] = React.useState(SEED_CUSTOMERS);
  const [userAccounts, setUserAccounts] = React.useState(USER_ACCOUNTS);
  const [quotes, setQuotes] = React.useState([]);
  const [tourPrograms, setTourPrograms] = React.useState(SEED_TOUR_PROGRAMS);
  const [bankAccounts, setBankAccounts] = React.useState(SEED_BANK_ACCOUNTS);
  const [personalTargets, setPersonalTargets] = React.useState(SEED_PERSONAL_TARGETS);
  const [outputInvoices, setOutputInvoices] = React.useState(SEED_OUTPUT_INVOICES);
  const [inputInvoices, setInputInvoices] = React.useState(SEED_INPUT_INVOICES);
  const [bookings, setBookings] = React.useState(SEED_NCC_BOOKINGS);
  const [credits, setCredits] = React.useState(SEED_CREDITS);
  const [notifs, setNotifs] = React.useState([]);
  const [nccListGlobal, setNccListGlobal] = React.useState(SEED_NCC_MASTER);
  const [hdvList, setHdvList] = React.useState([]);
  const [products, setProducts] = React.useState([]);
  const [careTasks, setCareTasks] = React.useState([]);
  const [msgHistory, setMsgHistory] = React.useState([]);
  const [approvalThreshold, setApprovalThreshold] = React.useState(20000000);
  const [showNotif, setShowNotif] = React.useState(false);
  const [showSearch, setShowSearch] = React.useState(false);
  const [selected, setSelected] = React.useState(null);
  const [showLogoutConfirm, setShowLogoutConfirm] = React.useState(false);
  const [toasts, setToasts] = React.useState([]);

  const currentRole = currentUser?.role || "sale";

  const pushToast = (msg, type="success") => {
    const id = Date.now();
    setToasts(t => [...t, {id, msg, type}]);
    setTimeout(() => setToasts(t => t.filter(x => x.id !== id)), 4000);
  };

  const pushNotif = (msg, type, extra={}) => {
    const id = Date.now();
    setNotifs(n => [{id, msg, type, time: new Date().toISOString(), read: false, ...extra}, ...n]);
    pushToast(msg, type === "success" ? "success" : "error");
  };

  if(!currentUser){
    return <LoginPage onLogin={u => setCurrentUser(u)} userAccounts={userAccounts}/>;
  }

  return (
    <div style={{minHeight:"100vh",background:"#f8fafc",display:"flex"}}>
      <Sidebar
        currentRole={currentRole}
        view={view}
        onNav={v => setView(v)}
        currentUser={currentUser}
        onLogout={() => setCurrentUser(null)}
        notifs={notifs}
        onNotif={() => setShowNotif(v => !v)}
        onSearch={() => setShowSearch(true)}
      >
        {view==="dashboard" && (
          <div>
            <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:16,marginBottom:24}}>
              {[
                {label:"Tổng đơn hàng",value:orders.length,icon:"📋",color:"#3b82f6"},
                {label:"Doanh thu",value:fmt(orders.reduce((s,o)=>s+o.totalPrice,0))+" đ",icon:"💰",color:"#10b981"},
                {label:"Đã thu",value:fmt(orders.reduce((s,o)=>s+o.totalPaid,0))+" đ",icon:"✅",color:"#8b5cf6"},
                {label:"Còn nợ",value:fmt(orders.reduce((s,o)=>s+(o.totalPrice-o.totalPaid),0))+" đ",icon:"⚠️",color:"#f59e0b"},
              ].map(c=>(
                <div key={c.label} style={{background:"#fff",borderRadius:12,padding:20,boxShadow:"0 1px 4px rgba(0,0,0,.08)"}}>
                  <div style={{fontSize:24,marginBottom:8}}>{c.icon}</div>
                  <div style={{fontSize:13,color:"#64748b",marginBottom:4}}>{c.label}</div>
                  <div style={{fontSize:20,fontWeight:700,color:c.color}}>{c.value}</div>
                </div>
              ))}
            </div>
            <div style={{background:"#fff",borderRadius:12,padding:20,boxShadow:"0 1px 4px rgba(0,0,0,.08)"}}>
              <div style={{fontWeight:600,marginBottom:12}}>Đơn hàng gần đây</div>
              <table style={{width:"100%",borderCollapse:"collapse",fontSize:13}}>
                <thead><tr style={{borderBottom:"2px solid #f1f5f9"}}>{["Mã đơn","Khách hàng","Sản phẩm","Trạng thái","Doanh thu"].map(h=><th key={h} style={{textAlign:"left",padding:"8px 12px",color:"#64748b",fontWeight:600}}>{h}</th>)}</tr></thead>
                <tbody>{orders.slice(0,5).map(o=>(
                  <tr key={o.id} style={{borderBottom:"1px solid #f8fafc"}} onClick={()=>{setSelected(o);setView("orders");}}>
                    <td style={{padding:"10px 12px",color:"#3b82f6",fontWeight:600,cursor:"pointer"}}>{o.id}</td>
                    <td style={{padding:"10px 12px"}}>{o.customer?.name}</td>
                    <td style={{padding:"10px 12px"}}>{o.product}</td>
                    <td style={{padding:"10px 12px"}}><span style={{padding:"3px 10px",borderRadius:20,fontSize:11,fontWeight:600,background:o.status==="completed"?"#dcfce7":o.status==="confirmed"?"#dbeafe":o.status==="pending_payment"?"#fef9c3":"#fee2e2",color:o.status==="completed"?"#16a34a":o.status==="confirmed"?"#1d4ed8":o.status==="pending_payment"?"#ca8a04":"#dc2626"}}>{o.status}</span></td>
                    <td style={{padding:"10px 12px",fontWeight:600}}>{fmt(o.totalPrice)} đ</td>
                  </tr>
                ))}</tbody>
              </table>
            </div>
          </div>
        )}
        {view==="orders" && (
          <div style={{background:"#fff",borderRadius:12,padding:20,boxShadow:"0 1px 4px rgba(0,0,0,.08)"}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
              <div style={{fontWeight:700,fontSize:16}}>Danh sách đơn hàng</div>
              <button onClick={()=>setView("create")} style={{background:"#3b82f6",color:"#fff",border:"none",padding:"8px 16px",borderRadius:8,cursor:"pointer",fontWeight:600}}>+ Tạo đơn mới</button>
            </div>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:13}}>
              <thead><tr style={{background:"#f8fafc"}}>{["Mã đơn","Khách hàng","Sản phẩm","Sale","Ngày đi","Tổng tiền","Đã thu","Trạng thái"].map(h=><th key={h} style={{textAlign:"left",padding:"10px 12px",color:"#64748b",fontWeight:600,borderBottom:"2px solid #e2e8f0"}}>{h}</th>)}</tr></thead>
              <tbody>{orders.map(o=>(
                <tr key={o.id} style={{borderBottom:"1px solid #f1f5f9",cursor:"pointer"}} onMouseOver={e=>e.currentTarget.style.background="#f8fafc"} onMouseOut={e=>e.currentTarget.style.background=""} onClick={()=>{setSelected(o);setView("detail");}}>
                  <td style={{padding:"10px 12px",color:"#3b82f6",fontWeight:600}}>{o.id}</td>
                  <td style={{padding:"10px 12px"}}>{o.customer?.name}<br/><span style={{fontSize:11,color:"#94a3b8"}}>{o.customer?.phone}</span></td>
                  <td style={{padding:"10px 12px"}}>{o.product}</td>
                  <td style={{padding:"10px 12px"}}>{o.saleName}</td>
                  <td style={{padding:"10px 12px"}}>{o.departDate}</td>
                  <td style={{padding:"10px 12px",fontWeight:600}}>{fmt(o.totalPrice)} đ</td>
                  <td style={{padding:"10px 12px",color:"#10b981"}}>{fmt(o.totalPaid)} đ</td>
                  <td style={{padding:"10px 12px"}}><span style={{padding:"3px 10px",borderRadius:20,fontSize:11,fontWeight:600,background:o.status==="completed"?"#dcfce7":o.status==="confirmed"?"#dbeafe":"#fef9c3",color:o.status==="completed"?"#16a34a":o.status==="confirmed"?"#1d4ed8":"#ca8a04"}}>{o.status}</span></td>
                </tr>
              ))}</tbody>
            </table>
          </div>
        )}
        {view==="create" && (
          <div style={{background:"#fff",borderRadius:12,padding:24,maxWidth:600,boxShadow:"0 1px 4px rgba(0,0,0,.08)"}}>
            <div style={{fontWeight:700,fontSize:16,marginBottom:20}}>Tạo đơn hàng mới</div>
            <SimpleOrderForm onSave={d=>{const newId="DH"+Date.now().toString().slice(-6);setOrders(p=>[{...d,id:newId,createdAt:new Date().toISOString(),status:"pending_payment",totalPaid:0},...p]);setView("orders");pushToast("Đã tạo đơn "+newId);}} onCancel={()=>setView("orders")} currentUser={currentUser}/>
          </div>
        )}
        {view==="detail"&&selected && (
          <div style={{background:"#fff",borderRadius:12,padding:24,boxShadow:"0 1px 4px rgba(0,0,0,.08)"}}>
            <button onClick={()=>setView("orders")} style={{background:"#f1f5f9",border:"none",padding:"6px 14px",borderRadius:6,cursor:"pointer",marginBottom:16}}>← Quay lại</button>
            <div style={{fontWeight:700,fontSize:18,marginBottom:16}}>Chi tiết đơn: {selected.id}</div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
              {[["Khách hàng",selected.customer?.name],["Điện thoại",selected.customer?.phone],["Sản phẩm",selected.product],["Sale phụ trách",selected.saleName],["Ngày đi",selected.departDate],["Ngày về",selected.returnDate],["Số khách",selected.pax+" người"],["Trạng thái",selected.status],["Tổng tiền",fmt(selected.totalPrice)+" đ"],["Đã thu",fmt(selected.totalPaid)+" đ"],["Còn nợ",fmt((selected.totalPrice||0)-(selected.totalPaid||0))+" đ"],["Ghi chú",selected.notes||"—"]].map(([k,v])=>(
                <div key={k} style={{padding:12,background:"#f8fafc",borderRadius:8}}><div style={{fontSize:11,color:"#94a3b8",marginBottom:4}}>{k}</div><div style={{fontWeight:600}}>{v}</div></div>
              ))}
            </div>
          </div>
        )}
        {view==="crm" && (
          <div style={{background:"#fff",borderRadius:12,padding:20,boxShadow:"0 1px 4px rgba(0,0,0,.08)"}}>
            <div style={{fontWeight:700,fontSize:16,marginBottom:16}}>Danh sách khách hàng</div>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:13}}>
              <thead><tr style={{background:"#f8fafc"}}>{["Tên","Điện thoại","Email","Tỉnh/TP","Số đơn"].map(h=><th key={h} style={{textAlign:"left",padding:"10px 12px",color:"#64748b",fontWeight:600,borderBottom:"2px solid #e2e8f0"}}>{h}</th>)}</tr></thead>
              <tbody>{customers.map(c=>(
                <tr key={c.id} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"10px 12px",fontWeight:600}}>{c.name}</td>
                  <td style={{padding:"10px 12px"}}>{c.phone}</td>
                  <td style={{padding:"10px 12px"}}>{c.email||"—"}</td>
                  <td style={{padding:"10px 12px"}}>{c.province||"—"}</td>
                  <td style={{padding:"10px 12px"}}>{orders.filter(o=>o.customer?.phone===c.phone).length}</td>
                </tr>
              ))}</tbody>
            </table>
          </div>
        )}
        {view==="users" && (
          <div style={{background:"#fff",borderRadius:12,padding:20,boxShadow:"0 1px 4px rgba(0,0,0,.08)"}}>
            <div style={{fontWeight:700,fontSize:16,marginBottom:16}}>Quản lý nhân viên</div>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:13}}>
              <thead><tr style={{background:"#f8fafc"}}>{["Avatar","Tên","Username","Phòng ban","Vai trò"].map(h=><th key={h} style={{textAlign:"left",padding:"10px 12px",color:"#64748b",fontWeight:600,borderBottom:"2px solid #e2e8f0"}}>{h}</th>)}</tr></thead>
              <tbody>{userAccounts.map(u=>(
                <tr key={u.id} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"10px 12px"}}><div style={{width:32,height:32,borderRadius:"50%",background:"#3b82f6",color:"#fff",display:"flex",alignItems:"center",justifyContent:"center",fontWeight:700}}>{u.avatar}</div></td>
                  <td style={{padding:"10px 12px",fontWeight:600}}>{u.name}</td>
                  <td style={{padding:"10px 12px",color:"#64748b"}}>{u.username}</td>
                  <td style={{padding:"10px 12px"}}>{u.dept}</td>
                  <td style={{padding:"10px 12px"}}><span style={{padding:"3px 10px",borderRadius:20,fontSize:11,fontWeight:600,background:"#dbeafe",color:"#1d4ed8"}}>{u.role}</span></td>
                </tr>
              ))}</tbody>
            </table>
          </div>
        )}
        {view==="profile" && (
          <div style={{background:"#fff",borderRadius:12,padding:24,maxWidth:500,boxShadow:"0 1px 4px rgba(0,0,0,.08)"}}>
            <div style={{fontWeight:700,fontSize:16,marginBottom:20}}>Hồ sơ cá nhân</div>
            <div style={{display:"flex",alignItems:"center",gap:16,marginBottom:24}}>
              <div style={{width:64,height:64,borderRadius:"50%",background:"#3b82f6",color:"#fff",display:"flex",alignItems:"center",justifyContent:"center",fontSize:24,fontWeight:700}}>{currentUser.avatar}</div>
              <div><div style={{fontWeight:700,fontSize:18}}>{currentUser.name}</div><div style={{color:"#64748b"}}>{currentUser.role} — {currentUser.dept}</div></div>
            </div>
            {[["Username",currentUser.username],["Phòng ban",currentUser.dept],["Vai trò",currentUser.role]].map(([k,v])=>(
              <div key={k} style={{display:"flex",justifyContent:"space-between",padding:"12px 0",borderBottom:"1px solid #f1f5f9"}}><span style={{color:"#64748b"}}>{k}</span><span style={{fontWeight:600}}>{v}</span></div>
            ))}
            <button onClick={()=>setCurrentUser(null)} style={{marginTop:24,width:"100%",background:"#ef4444",color:"#fff",border:"none",padding:"10px",borderRadius:8,cursor:"pointer",fontWeight:600}}>🚪 Đăng xuất</button>
          </div>
        )}
        {["ncc","quote","invoice","report","approvals","accounting","close","refund","tourghep","aftersale","hdv","tour"].includes(view) && (
          <div style={{background:"#fff",borderRadius:12,padding:40,textAlign:"center",boxShadow:"0 1px 4px rgba(0,0,0,.08)"}}>
            <div style={{fontSize:48,marginBottom:16}}>{NAV_ITEMS.find(n=>n.key===view)?.icon}</div>
            <div style={{fontWeight:700,fontSize:20,marginBottom:8}}>{NAV_ITEMS.find(n=>n.key===view)?.label}</div>
            <div style={{color:"#94a3b8",fontSize:14}}>Module này đang được phát triển.<br/>Vui lòng quay lại sau.</div>
          </div>
        )}
      </Sidebar>
      {toasts.map(t => (
        <div key={t.id} style={{position:"fixed",bottom:24,right:24,background:t.type==="error"?"#ef4444":"#22c55e",color:"#fff",padding:"12px 20px",borderRadius:8,zIndex:9999,boxShadow:"0 4px 16px rgba(0,0,0,.2)"}}>
          {t.msg}
        </div>
      ))}
    </div>
  );
}