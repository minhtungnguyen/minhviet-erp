function AuditLog({ log }){
  const actionCfg={
    created:  {label:"Tạo yêu cầu",    color:"#888",    icon:"📝"},
    approved: {label:"Đã duyệt",       color:"#2563eb", icon:"✓"},
    rejected: {label:"Từ chối",        color:"#b0554a", icon:"✕"},
    modified: {label:"Sửa số tiền",    color:"#7a5a00", icon:"✏️"},
    paid:     {label:"Đã chuyển tiền", color:"#1a4d8f", icon:"💸"},
    escalated:{label:"Chuyển cấp trên",color:"#5c2eb0", icon:"⬆"},
  };
  return(
    <div>
      {log.map((e,i)=>{
        const cfg=actionCfg[e.action]||{label:e.action,color:"#888",icon:"•"};
        return(
          <div key={i} style={{display:"flex",gap:10,padding:"8px 0",borderBottom:i<log.length-1?"1px solid #f0efe8":"none"}}>
            <div style={{display:"flex",flexDirection:"column",alignItems:"center",flexShrink:0}}>
              <div style={{width:28,height:28,borderRadius:"50%",background:cfg.color+"18",display:"flex",alignItems:"center",justifyContent:"center",fontSize:13}}>{cfg.icon}</div>
              {i<log.length-1&&<div style={{width:1,flex:1,background:"#dbeafe",marginTop:4}}/>}
            </div>
            <div style={{flex:1,paddingBottom:i<log.length-1?8:0}}>
              <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:2}}>
                <span style={{fontSize:12,fontWeight:600,color:cfg.color}}>{cfg.label}</span>
                <span style={{fontSize:11,color:"#aaa"}}>{fmtDT(e.ts)}</span>
              </div>
              <div style={{fontSize:12,fontWeight:500,color:"#444"}}>{e.actor}
                <span style={{fontSize:11,color:"#aaa",marginLeft:6,textTransform:"capitalize"}}>({e.role})</span>
              </div>
              {e.note&&<div style={{fontSize:11,color:"#888",marginTop:2,fontStyle:"italic"}}>"{e.note}"</div>}
              {e.oldAmount&&<div style={{fontSize:11,color:"#b0554a",marginTop:2}}>Sửa: {fmt(e.oldAmount)} đ → {fmt(e.newAmount)} đ</div>}
            </div>
          </div>
        );
      })}
    </div>
  );
}

