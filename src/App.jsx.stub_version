function OpsCalendar({orders,ops,calMonth,setCalMonth,setSelectedId,setTab,daysUntil}){
  const y=calMonth.y, m=calMonth.m;
  const now=new Date(NOW_ISO);
  const firstDay=new Date(y,m,1);
  const startDow=firstDay.getDay();
  const startOffset=startDow===0?6:startDow-1;
  const daysInMonth=new Date(y,m+1,0).getDate();
  const totalCells=Math.ceil((startOffset+daysInMonth)/7)*7;
  const MONTHS=["Tháng 1","Tháng 2","Tháng 3","Tháng 4","Tháng 5","Tháng 6","Tháng 7","Tháng 8","Tháng 9","Tháng 10","Tháng 11","Tháng 12"];
  const DOW=["T2","T3","T4","T5","T6","T7","CN"];
  const SVC=Object.fromEntries(SERVICES.map(s=>[s.id,s]));
  const isToday=(d)=>now.getFullYear()===y&&now.getMonth()===m&&now.getDate()===d;

  const departMap={}; const returnMap={};
  orders.filter(o=>!["cancelled"].includes(o.status)).forEach(o=>{
    if(o.departDate){const d=new Date(o.departDate);if(d.getFullYear()===y&&d.getMonth()===m){const k=d.getDate();if(!departMap[k])departMap[k]=[];departMap[k].push(o);}}
    if(o.returnDate){const d=new Date(o.returnDate);if(d.getFullYear()===y&&d.getMonth()===m){const k=d.getDate();if(!returnMap[k])returnMap[k]=[];returnMap[k].push(o);}}
  });

  const allDepart=orders.filter(o=>{if(!o.departDate||["cancelled"].includes(o.status))return false;const d=new Date(o.departDate);return d.getFullYear()===y&&d.getMonth()===m;});
  const allReturn=orders.filter(o=>{if(!o.returnDate||["cancelled"].includes(o.status))return false;const d=new Date(o.returnDate);return d.getFullYear()===y&&d.getMonth()===m;});

  const svcColor=(id)=>{const c={ve_may_bay:"#2563eb",tour:"#1d6b4f",tour_ghep_nd:"#5c2eb0",tour_ghep_qt:"#7c3aed",cruise:"#0891b2",hotel_flight:"#7a5a00",ve_tham_quan:"#b45309",khach_san:"#b0554a",visa:"#475569",bao_hiem:"#1e3a8a",thue_xe:"#064e3b",mice_teambuilding:"#7e22ce"};return c[id]||"#64748b";};

  const prevM=()=>setCalMonth(({y,m})=>m===0?{y:y-1,m:11}:{y,m:m-1});
  const nextM=()=>setCalMonth(({y,m})=>m===11?{y:y+1,m:0}:{y,m:m+1});
  const goNow=()=>setCalMonth({y:now.getFullYear(),m:now.getMonth()});

  return(
    <div>

      <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:10,marginBottom:14}}>
        {[
          {l:"Khởi hành "+(MONTHS[m]), v:allDepart.length, c:"#1e3a8a", icon:"✈"},
          {l:"Trở về "+(MONTHS[m]),    v:allReturn.length,  c:"#1d6b4f", icon:"🏠"},
          {l:"Hôm nay khởi hành",      v:departMap[now.getDate()]?.length||0, c:departMap[now.getDate()]?.length>0?"#b0554a":"#888", icon:"🔴"},
          {l:"Tổng đơn active",        v:orders.filter(o=>!["cancelled","completed"].includes(o.status)).length, c:"#5c2eb0", icon:"📋"},
        ].map(({l,v,c,icon})=>(
          <Card key={l} style={{padding:"11px 14px",display:"flex",alignItems:"center",gap:10}}>
            <span style={{fontSize:20}}>{icon}</span>
            <div>
              <div style={{fontSize:10,color:"#64748b",textTransform:"uppercase",letterSpacing:.3}}>{l}</div>
              <div style={{fontSize:20,fontWeight:700,color:c}}>{v}</div>
            </div>
          </Card>
        ))}
      </div>


      <Card style={{padding:0,overflow:"hidden"}}>

        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"12px 16px",background:"linear-gradient(135deg,#1e3a8a,#2563eb)"}}>
          <button onClick={prevM} style={{background:"rgba(255,255,255,.15)",border:"none",color:"#fff",fontSize:20,cursor:"pointer",borderRadius:8,width:34,height:34,display:"flex",alignItems:"center",justifyContent:"center"}}>{"<"}</button>
          <div style={{textAlign:"center"}}>
            <div style={{fontSize:17,fontWeight:700,color:"#fff"}}>{MONTHS[m]} {y}</div>
            <div style={{fontSize:11,color:"rgba(255,255,255,.7)",marginTop:2}}>{allDepart.length} khởi hành - {allReturn.length} trở về</div>
          </div>
      <div class="vc-code-wrap">
        <div><div class="vc-code-label">Mã voucher</div><div class="vc-code-val">${code}</div></div>
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="52" height="52" rx="6" fill="${scheme.badge}"/>
          <text x="50%" y="54%" dominant-baseline="middle" text-anchor="middle" font-size="28" fill="${scheme.accent}">🎁</text>
        </svg>
      </div>

      <div class="vc-meta">
        <div class="vc-meta-item"><div class="vc-meta-label">Ngày cấp</div><div class="vc-meta-val">${today}</div></div>
        <div class="vc-meta-item"><div class="vc-meta-label">Hạn sử dụng</div><div class="vc-meta-val">${expiryFmt}</div></div>
        ${issuedBy ? "<div class=\"vc-meta-item\"><div class=\"vc-meta-label\">Người cấp</div><div class=\"vc-meta-val\">"+(issuedBy)+"</div></div>" : ""}
      </div>

      ${note
        ? "<div class=\"vc-note\">* "+(note)+"</div>"
        : isFixed
        ? "<div class=\"vc-note\">* Voucher trị giá "+(heroLabel)+" - Áp dụng 1 lần - Không quy đổi thành tiền mặt - Liên hệ "+(COMPANY.phone)+" để đặt dịch vụ.</div>"
        : "<div class=\"vc-note\">* Voucher chỉ áp dụng 1 lần - Không quy đổi thành tiền mặt - Liên hệ "+(COMPANY.phone)+" để đặt dịch vụ.</div>"}
    </div>
  </div>
</div>

<div class="no-print" style="text-align:center;margin-top:16px;display:flex;gap:10px;justify-content:center;">
  <button onclick="window.print()" style="padding:9px 24px;background:#1e3a8a;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;">🖨 In Voucher</button>
  <button onclick="window.close()" style="padding:9px 20px;background:#f1f5f9;color:#475569;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;cursor:pointer;">Đóng</button>
</div>
</body></html>`;
}

