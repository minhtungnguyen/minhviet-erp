function CrmTagBadge({tagId,size="md"}){
  const t=CRM_TAGS.find(x=>x.id===tagId)||{label:tagId,color:"#888",bg:"#f0f0f0"};
  return <span style={{display:"inline-flex",alignItems:"center",fontSize:size==="sm"?10:11,fontWeight:600,padding:size==="sm"?"2px 7px":"3px 9px",borderRadius:20,background:t.bg,color:t.color,whiteSpace:"nowrap"}}>{t.label}</span>;
}
function InteractionIcon({type}){
  const icons = {order:"📋",call:"📞",email:"✉️",meet:"🤝",note:"📝",zalo:"💬"};
  return <span style={{fontSize:14}}>{icons[type]||"•"}</span>;
}

// Tính ngày sự kiện tiếp theo trong năm
function nextOccurrence(dateStr){
  if(!dateStr) return null;
  const now=new Date(NOW_ISO);
  const d=new Date(dateStr);
  let next=new Date(now.getFullYear(),d.getMonth(),d.getDate());
  if(next<now) next=new Date(now.getFullYear()+1,d.getMonth(),d.getDate());
  return Math.ceil((next-now)/86400000);
}
function yearsElapsed(dateStr){
  if(!dateStr) return 0;
  return new Date(NOW_ISO).getFullYear()-new Date(dateStr).getFullYear();
}

// Build thiệp nội dung
function buildMessage(template,c,event){
  const years=yearsElapsed(event.date);
  const honorific=c.type==="business"?"quý công ty":"anh/chị";
  return template
    .replace(/{name}/g,   c.type==="business"?(c.companyName||c.name):c.name)
    .replace(/{honorific}/g, honorific)
    .replace(/{years}/g,  years)
    .replace(/{companyName}/g, c.companyName||c.name)
    .replace(/{year}/g,   new Date(NOW_ISO).getFullYear())
    .replace(/{discount}/g, years>=3?"10":years>=1?"7":"5");
}

// ── Customer Card ─────────────────────────────────────────
function CustomerCard({c,orders,onView}){
  const isBiz=c.type==="business";
  const cOrders=orders.filter(o=>o.customer?.phone===c.phone);
  const hasDebt=cOrders.some(o=>["pending_payment","confirmed","partial_paid"].includes(o.status));
  // Upcoming events (next 30 days)
  const urgentEvents=(c.events||[]).filter(e=>e.yearly&&nextOccurrence(e.date)<=30);
  return(
    <div onClick={()=>onView(c)} style={{background:"#fff",borderRadius:12,border:"1px solid #e0e7ff",padding:"14px 16px",cursor:"pointer",transition:"box-shadow .15s",position:"relative"}}
      onMouseEnter={e=>e.currentTarget.style.boxShadow="0 4px 16px rgba(30,58,138,.1)"}
      onMouseLeave={e=>e.currentTarget.style.boxShadow="none"}>

      <div style={{position:"absolute",top:10,right:10,fontSize:10,fontWeight:600,padding:"2px 7px",borderRadius:20,background:isBiz?"#f3f0ff":"#eff6ff",color:isBiz?"#5c2eb0":"#2563eb"}}>
        {isBiz?"🏢 DN":"👤 CN"}
      </div>
      <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:8}}>
        <div style={{width:38,height:38,borderRadius:"50%",background:isBiz?"linear-gradient(135deg,#5c2eb0,#7c3aed)":"linear-gradient(135deg,#1e3a8a,#3b82f6)",display:"flex",alignItems:"center",justifyContent:"center",color:"#fff",fontSize:14,fontWeight:700,flexShrink:0}}>
          {isBiz?"🏢":c.name.split(" ").pop()[0]}
        </div>
        <div style={{minWidth:0,flex:1}}>
          <div style={{fontSize:13,fontWeight:600,color:"#1e293b",whiteSpace:"nowrap",overflow:"hidden",textOverflow:"ellipsis"}}>{isBiz?c.companyName:c.name}</div>
          {isBiz&&<div style={{fontSize:11,color:"#64748b"}}>👤 {c.name} - {c.phone}</div>}
          {!isBiz&&<div style={{fontSize:11,color:"#64748b"}}>{c.phone}</div>}
          {isBiz&&c.taxCode&&<div style={{fontSize:10,color:"#94a3b8"}}>MST: {c.taxCode}{c.director?" - GĐ: "+(c.director):""}</div>}
        </div>
      </div>
      <div style={{display:"flex",gap:4,flexWrap:"wrap",marginBottom:8}}>
        {c.tags.map(t=><CrmTagBadge key={t} tagId={t} size="sm"/>)}
      </div>
      {urgentEvents.length>0&&(
        <div style={{background:"#fdf2f8",border:"1px solid #fbcfe8",borderRadius:8,padding:"5px 9px",marginBottom:8,fontSize:11,color:"#be185d",fontWeight:500}}>
          {urgentEvents.map(e=>{const d=nextOccurrence(e.date);return <span key={e.id}>{CRM_EVENT_TYPES[e.type]?.icon||"📅"} {e.label}: {d===0?"Hôm nay!":d+"ngày nữa"} - </span>;})}
        </div>
      )}
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:5}}>
        {[{l:"Đơn",v:c.totalOrders},{l:"DT",v:fmtS(c.totalRevenue)+"đ"},{l:"LN",v:fmtS(c.totalProfit)+"đ"}].map(({l,v})=>(
          <div key={l} style={{textAlign:"center",background:"#f0f4ff",borderRadius:6,padding:"4px 5px"}}>
            <div style={{fontSize:10,color:"#94a3b8"}}>{l}</div>
            <div style={{fontSize:11,fontWeight:700,color:"#1e293b",fontVariantNumeric:"tabular-nums"}}>{v}</div>
          </div>
        ))}
      </div>
      {hasDebt&&<div style={{marginTop:6,fontSize:10,color:"#b0554a",fontWeight:600,background:"#fdf0ee",borderRadius:5,padding:"2px 7px",display:"inline-block"}}>Còn nợ</div>}
    </div>
  );
}

// ── Message Composer (thiệp/email) ────────────────────────
function MessageComposer({c,event,onClose,onSend,currentUser}){ return null; }
function genVoucherCode(customerName, discount) {

  const discountColor = discount>=20?"#7c2d12": discount>=10?"#1d4d1a":"#1e3a8a";
  const discountBg    = discount>=20?"#fdf0ee": discount>=10?"#f0fdf4":"#eff6ff";

  return(
    <div style={{marginBottom:12,background:"#fff",borderRadius:12,border:"1px solid #e0e7ff",overflow:"hidden"}}>
      <button onClick={()=>setOpen(v=>!v)}
        style={{width:"100%",display:"flex",alignItems:"center",justifyContent:"space-between",
          padding:"13px 16px",background:"none",border:"none",cursor:"pointer",textAlign:"left"}}>
        <div style={{display:"flex",alignItems:"center",gap:8}}>
          <span style={{fontWeight:600,fontSize:14}}>🎁 Tạo Voucher Khuyến Mãi</span>
          <span style={{fontSize:11,padding:"2px 8px",borderRadius:20,background:discountBg,color:discountColor,fontWeight:700}}>-{discount}%</span>
        </div>
        <span style={{fontSize:12,color:"#64748b"}}>{open?"▲":"▼"}</span>
      </button>

      {open&&(
        <div style={{padding:"0 16px 18px"}}>

          {/* Discount % */}
          <div style={{marginBottom:14}}>
            <div style={{fontSize:11,fontWeight:600,color:"#64748b",textTransform:"uppercase",letterSpacing:.4,marginBottom:8}}>Mức giảm giá</div>
            <div style={{display:"flex",gap:8}}>
              {[5,10,15,20,30].map(pct=>(
                <button key={pct} onClick={()=>setDiscount2(pct)}
                  style={{flex:1,padding:"10px 0",borderRadius:10,border:"2px solid "+(discount===pct?discountColor:"#e0e7ff"),
                    background:discount===pct?discountBg:"#f8faff",
                    color:discount===pct?discountColor:"#64748b",
                    fontWeight:discount===pct?800:500,fontSize:14,cursor:"pointer",transition:"all .15s"}}>
                  -{pct}%
                </button>
              ))}
            </div>
          </div>

          {/* Services */}
          <div style={{marginBottom:14}}>
            <div style={{fontSize:11,fontWeight:600,color:"#64748b",textTransform:"uppercase",letterSpacing:.4,marginBottom:8}}>
              Áp dụng cho dịch vụ
              <span style={{marginLeft:6,fontSize:10,fontWeight:400,color:"#94a3b8"}}>(chọn nhiều)</span>
            </div>
            <div style={{display:"flex",flexWrap:"wrap",gap:6}}>
              {VOUCHER_SERVICES.map(svc=>{
                const on=services.includes(svc);
                return(
                  <button key={svc} onClick={()=>toggleService(svc)}
                    style={{padding:"5px 11px",borderRadius:20,border:"1.5px solid "+(on?discountColor:"#e0e7ff"),
                      background:on?discountBg:"#f8faff",color:on?discountColor:"#64748b",
                      fontSize:12,fontWeight:on?600:400,cursor:"pointer",transition:"all .12s"}}>
                    {on?"✓ ":""}{svc}
                  </button>
                );
              })}
            </div>
          </div>

          {/* Expiry + Code */}
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:14}}>
            <FieldWrap label="Hạn sử dụng">
              <input type="date" value={expiry} onChange={e=>setExpiry(e.target.value)}
                style={{width:"100%",padding:"9px 12px",border:"1px solid #dbeafe",borderRadius:8,fontSize:13,background:"#f8faff",outline:"none",boxSizing:"border-box"}}/>
            </FieldWrap>
            <FieldWrap label="Mã voucher">
              <div style={{display:"flex",gap:6}}>
                <input value={code} onChange={e=>setCode(e.target.value.toUpperCase())}
                  style={{flex:1,padding:"9px 12px",border:"1px solid #dbeafe",borderRadius:8,fontSize:12,
                    fontFamily:"monospace",fontWeight:700,background:"#f8faff",outline:"none",letterSpacing:1}}/>
                <button onClick={()=>setCode(genVoucherCode(c.name,discount))}
                  style={{padding:"0 10px",border:"1px solid #dbeafe",borderRadius:8,background:"#f0f4ff",
                    color:"#1e3a8a",cursor:"pointer",fontSize:16}} title="Tạo mã mới">↻</button>
              </div>
            </FieldWrap>
          </div>

          {/* Note */}
          <FieldWrap label="Điều kiện / ghi chú in trên voucher (tùy chọn)">
            <input value={note} onChange={e=>setNote(e.target.value)}
              placeholder="VD: Áp dụng cho đặt tour từ 2 người trở lên..."
              style={{width:"100%",padding:"9px 12px",border:"1px solid #dbeafe",borderRadius:8,fontSize:13,background:"#f8faff",outline:"none",boxSizing:"border-box"}}/>
          </FieldWrap>

          {/* Preview strip */}
          <div style={{background:"linear-gradient(135deg,"+(discountColor)+",#3b82f6)",borderRadius:10,
            padding:"12px 16px",marginTop:14,marginBottom:14,display:"flex",alignItems:"center",gap:14,color:"#fff"}}>
            <div style={{fontSize:28,fontWeight:900,lineHeight:1}}>-{discount}%</div>
            <div style={{flex:1}}>
              <div style={{fontSize:13,fontWeight:700}}>{c.name}</div>
              <div style={{fontSize:11,opacity:.8}}>{services.slice(0,3).join(" - ")}{services.length>3?" - ...":""}</div>
            </div>
            <div style={{textAlign:"right"}}>
              <div style={{fontFamily:"monospace",fontSize:13,fontWeight:700,letterSpacing:1.5}}>{code}</div>
              <div style={{fontSize:10,opacity:.7}}>HSD: {expiry?new Date(expiry).toLocaleDateString("vi-VN"):"—"}</div>
            </div>
          </div>

          <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
            <button onClick={()=>{navigator.clipboard.writeText(code);pushNotif("Đã copy mã voucher","success");}}
              style={{padding:"8px 14px",border:"1px solid #bfdbfe",borderRadius:8,background:"#f0f4ff",
                color:"#1e3a8a",fontSize:12,fontWeight:600,cursor:"pointer"}}>
              📋 Copy mã
            </button>
            <button onClick={handlePrint}
              style={{padding:"8px 20px",border:"none",borderRadius:8,
                background:"linear-gradient(135deg,"+(discountColor)+",#3b82f6)",
                color:"#fff",fontSize:13,fontWeight:700,cursor:"pointer",
                display:"flex",alignItems:"center",gap:6}}>
              🖨 In Voucher
            </button>
          </div>
        </div>
      )}
    </div>
  );
}

