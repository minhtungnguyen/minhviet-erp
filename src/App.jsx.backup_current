        {view==="accounting"&&<AccountingDashboard orders={orders} vouchers={vouchers} expenses={expenses} refunds={refunds} bankAccounts={bankAccounts} onUpdateBankAccounts={setBankAccounts} outputInvoices={outputInvoices} onUpdateOutputInvoices={setOutputInvoices} inputInvoices={inputInvoices} onUpdateInputInvoices={setInputInvoices} onApprove={handleApprove} onReject={handleReject} pushNotif={pushToast} currentUser={currentUser}/>}

        {view==="profile"&&<ProfilePage currentUser={currentUser} onUpdate={handleUpdateCurrentUser} onBack={()=>setView("orders")} pushNotif={pushToast}/>}

        {view==="users"&&currentRole==="manager"&&<UserManagementPage userAccounts={userAccounts} onUpdateAccounts={setUserAccounts} currentUser={currentUser} pushNotif={pushToast} personalTargets={personalTargets} onUpdateTargets={setPersonalTargets} approvalThreshold={approvalThreshold} onUpdateThreshold={setApprovalThreshold} onExportBackup={handleExportBackup} onImportBackup={handleImportBackup}/>}

        {view==="banks"&&<BankAccountModule bankAccounts={bankAccounts} onUpdate={setBankAccounts} pushNotif={pushToast}/>}

        {view==="reports"&&<ReportModule orders={orders} vouchers={vouchers} expenses={expenses} personalTargets={personalTargets} currentRole={currentRole} hdvList={hdvList}/>}

        {view==="tourghep"&&<TourGhepModule

            products={tourGhepProducts} onUpdate={setTourGhepProducts}

            orders={orders} currentRole={currentRole} currentUser={currentUser} pushNotif={pushToast}

            onCreateOrder={(p)=>{

              // Pre-select tour ghép product when creating a new order

              setView("create");

              // We pass via sessionStorage so OrderForm can pick it up

              sessionStorage.setItem("mv_prefill_tgp", JSON.stringify({

                serviceName: p.name,

                serviceType: p.service,

                departDate:  p.departDate,

                returnDate:  p.returnDate,

                slotPrice:   p.sellPrice,

                slotCost:    p.buyPrice,

                childPrice:  p.childPrice,

                buyChildPrice: p.buyChildPrice,

                tgpId:       p.id,

                operatorName: p.operatorName,

              }));

            }}

          />}

        {view==="aftercare"&&<AfterSaleModule careTasks={careTasks} onUpdateTasks={setCareTasks} orders={orders} customers={customers} currentUser={currentUser} currentRole={currentRole} pushNotif={pushToast}/>}

      </AppShell>



      {/* C?nh báo trùng ðõn */}

      {dupOrderDlg&&(

        <ConfirmModal

          title="?? Phát hi?n ðõn trùng!"

          warning={`Khách ${dupOrderDlg.pendingData?.customer?.name} ð? có ðõn ${dupOrderDlg.dupOrder?.id} — cùng d?ch v? "${dupOrderDlg.dupOrder?.serviceName}", ngày ði ${fmtD(dupOrderDlg.dupOrder?.departDate)}.`}

          message="B?n mu?n xem ðõn c? trý?c, hay v?n ti?p t?c t?o ðõn m?i?"

          confirmLabel="T?o ðõn m?i"

          confirmVariant="warning"

          onConfirm={()=>{

            setDupOrderDlg(null);

            handleCreateOrder(dupOrderDlg.pendingData, true); // bypass dup check

          }}

          onCancel={()=>{

            const dup=dupOrderDlg.dupOrder;

            setDupOrderDlg(null);

            setSelected(dup); setView("detail");

            pushToast("Ðang xem ðõn "+dup.id+" — ki?m tra trý?c khi t?o m?i","warning");

          }}

        />

      )}



      {/* Logout confirmation modal — không dùng window.confirm */}

      {showLogoutConfirm && (

        <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.5)",zIndex:3000,display:"flex",alignItems:"center",justifyContent:"center"}}

          onClick={()=>setShowLogoutConfirm(false)}>

          <div style={{background:"#fff",borderRadius:16,padding:"28px 32px",maxWidth:360,width:"90%",boxShadow:"0 24px 64px rgba(0,0,0,.3)",textAlign:"center"}}

            onClick={e=>e.stopPropagation()}>

            <div style={{fontSize:36,marginBottom:12}}>??</div>

            <div style={{fontSize:17,fontWeight:700,color:"#1e293b",marginBottom:6}}>Ðãng xu?t?</div>

            <div style={{fontSize:13,color:"#64748b",marginBottom:24}}>

              B?n s? thoát kh?i tài kho?n <strong>{currentUser?.name}</strong>.<br/>Phiên làm vi?c hi?n t?i s? k?t thúc.

            </div>

            <div style={{display:"flex",gap:10,justifyContent:"center"}}>

              <button onClick={()=>setShowLogoutConfirm(false)}

                style={{padding:"9px 22px",borderRadius:8,border:"1px solid #e2e8f0",background:"#f8fafc",color:"#475569",fontSize:13,fontWeight:600,cursor:"pointer"}}>

                ? l?i

              </button>

              <button onClick={()=>{ setShowLogoutConfirm(false); doLogout(); }}

                style={{padding:"9px 22px",borderRadius:8,border:"none",background:"#ef4444",color:"#fff",fontSize:13,fontWeight:600,cursor:"pointer"}}>

                Ðãng xu?t

              </button>

            </div>

          </div>

        </div>

      )}

    </>

  );

}






