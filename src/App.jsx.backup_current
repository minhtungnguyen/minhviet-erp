// daysUntilDepart vẫn giữ để dùng ở chỗ khác

function daysUntilDepart(departDateStr){

  const now    = new Date(NOW_ISO);

  const depart = new Date(departDateStr);

  return Math.max(0, Math.ceil((depart - now) / 86400000));

}



