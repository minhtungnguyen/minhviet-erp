    const allEvents=customers.flatMap(c=>(c.events||[]).filter(e=>e.yearly).map(e=>({...e,customer:c,daysLeft:nextOccurrence(e.date)})));
    const upcoming30=allEvents.filter(e=>e.daysLeft<=30).sort((a,b)=>a.daysLeft-b.daysLeft);
