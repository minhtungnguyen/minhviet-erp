function useTimeLimitState(timeLimitISO){

  const now   = new Date(NOW_ISO).getTime();

  const limit = new Date(timeLimitISO).getTime();

  const diffMs = limit - now;

  const diffH  = diffMs / 3600000;

  const expired = diffMs <= 0;

  const critical= !expired && diffH <= 2;

  const warning = !expired && !critical && diffH <= 24;

  const hoursLeft = Math.max(0, Math.floor(diffH));

  const minsLeft  = Math.max(0, Math.floor((diffMs % 3600000) / 60000));

  const label = expired ? "Hết hạn"

    : critical ? `${hoursLeft}h ${minsLeft}m`

    : warning  ? `${hoursLeft}h còn lại`

    : `${Math.floor(diffH / 24)}d ${hoursLeft % 24}h`;

  const color = expired||critical ? "#8b2a1a" : warning ? "#7a5a00" : "#2563eb";

  const bg    = expired||critical ? "#fdf0ee" : warning ? "#fef9e7" : "#eff6ff";

  return { expired, critical, warning, label, color, bg };

}






