              <div style={{fontSize:11,color:"#64748b",textTransform:"uppercase",letterSpacing:.4,marginBottom:2}}>{l}</div>

              <div style={{fontSize:20,fontWeight:700,color:c,fontVariantNumeric:"tabular-nums"}}>{v}</div>

